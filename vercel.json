{
  "redirects": [
    {
      "source": "/docs",
      "destination": "/docs/index.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/docs/:path*",
      "destination": "/docs/:path*"
    },
    {
      "source": "/openapi.yaml",
      "destination": "/openapi.yaml"
    },
    {
      "source": "/swagger.html",
      "destination": "/swagger.html"
    },
    {
      "source": "/static/:path*",
      "destination": "/static/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
